 )
@@ -59,8 +65,10 @@ func NewSession(
 	cfg *config.SQL,
 	d driver.Driver,
 	resolver resolver.ServiceResolver,
+	cred *azidentity.DefaultAzureCredential,
+	logger log.Logger,
 ) (*Session, error) {
-	db, err := createConnection(cfg, d, resolver)
+	db, err := createConnection(cfg, d, resolver, cred, logger)
 	if err != nil {
 		return nil, err
